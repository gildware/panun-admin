DUMP_BINARY_PATH=/usr/bin/

# =============================================================================
# WhatsApp / Meta (fill all that apply; no quotes around values)
# =============================================================================
#
# INTERNAL_WHATSAPP_API_TOKEN
#   Laravel route prefix: /api/internal/whatsapp/* — header: X-Internal-Token
#
# WHATSAPP_CLOUD_TOKEN
#   Meta Graph API access token (system user or long-lived), permissions:
#   whatsapp_business_messaging, whatsapp_business_management, etc.
#
# WHATSAPP_CLOUD_PHONE_ID
#   Sending number: WhatsApp → API setup → Phone number ID
#
# WHATSAPP_CLOUD_WABA_ID
#   WhatsApp Business Account ID — required for template list / create / sync
#
# WHATSAPP_CLOUD_APP_ID
#   Meta App ID (numeric, App Dashboard → Settings → Basic). Required only if you create
#   templates with IMAGE/VIDEO headers from this admin (Graph Resumable Upload API).
#
# WHATSAPP_CLOUD_VERSION
#   Graph API version (e.g. v19.0)
#
# WHATSAPP_APP_SECRET
#   Meta App → Settings → Basic → App secret — webhook POST signature check
#
# WHATSAPP_WEBHOOK_VERIFY_TOKEN
#   Any random string you invent — same value in Meta webhook “Verify token”
#   Callback URL: {APP_URL}/api/webhooks/whatsapp-marketing
#
INTERNAL_WHATSAPP_API_TOKEN=

WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=
WHATSAPP_CLOUD_WABA_ID=
WHATSAPP_CLOUD_APP_ID=
WHATSAPP_CLOUD_VERSION=v19.0

# Public HTTPS base where /public/storage/... is reachable by Meta (template DOCUMENT header + invoice PDF link).
# Meta cannot fetch localhost/private IPs. Production: usually same as APP_URL. Local: omit to upload PDF via API instead
# of a header link, or set to ngrok (same URL path as your app’s public storage).
# WHATSAPP_PUBLIC_MEDIA_BASE_URL=https://your-domain.com

# Optional: Meta WhatsApp Manager URL for “Create template” (defaults to Panun Kaergar WABA).
# WHATSAPP_META_MESSAGE_TEMPLATES_URL=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Facebook Messenger + Instagram DM (admin Social Inbox → Facebook / Instagram menus).
# Webhook URL (HTTPS, publicly reachable): {APP_URL}/api/webhooks/meta-social
# Meta → Webhooks → same Callback URL for Page and Instagram; Verify token = META_SOCIAL_WEBHOOK_VERIFY_TOKEN.
# App Secret signs requests (X-Hub-Signature-256); can match WHATSAPP_APP_SECRET if one Meta app.
META_SOCIAL_WEBHOOK_VERIFY_TOKEN=
META_SOCIAL_APP_SECRET=
# Page access token (pages_messaging). Used for Messenger outbound + optional IG if INSTAGRAM_DM_ACCESS_TOKEN unset.
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_GRAPH_VERSION=v19.0
# Instagram Professional account id (Graph “Instagram Business Account” id), for POST .../{id}/messages
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional: separate token for IG; defaults to MESSENGER_PAGE_ACCESS_TOKEN
# INSTAGRAM_DM_ACCESS_TOKEN=
INSTAGRAM_DM_GRAPH_VERSION=v19.0

# Booking → “open WhatsApp chat”: verify with Meta before opening (no chat if number is not on WhatsApp).
# Recommended: contacts check (no customer-visible message). Set false to rely on probe only.
WHATSAPP_OPEN_CHAT_USE_CONTACTS=true
# If contacts returns an error/ambiguous response, try a minimal outbound text (WHATSAPP_OPEN_CHAT_PROBE must be true).
# WHATSAPP_OPEN_CHAT_PROBE_FALLBACK=false
# When contacts is false: POST a minimal text to confirm delivery (customer may see it; default body ".").
WHATSAPP_OPEN_CHAT_PROBE=true
# WHATSAPP_OPEN_CHAT_PROBE_TEXT=.
# Local only: skip Cloud verification (NOT for production)
# WHATSAPP_ALLOW_OPEN_WITHOUT_GRAPH_VERIFY=false

# AI WhatsApp support (inbound messages → Gemini + tools). Same Meta webhook as marketing processes both.
GEMINI_API_KEY=
# Model for admin AI content generation (WhatsApp uses WHATSAPP_GEMINI_MODEL)
GEMINI_MODEL=gemini-2.5-flash
# When true (default), AI replies on inbound WhatsApp until an admin takes the chat (handled_by).
WHATSAPP_AI_SUPPORT_ENABLED=true
# How the WhatsApp AI job runs (after inbound message):
#   WHATSAPP_AI_DISPATCH_SYNC=true  → run AI inside the webhook (no queue worker). Pair with QUEUE_CONNECTION=sync.
#   WHATSAPP_AI_DISPATCH_SYNC=false → push ProcessWhatsAppAiSupportJob to Laravel’s queue. Pair with QUEUE_CONNECTION=database and run: php artisan queue:work
WHATSAPP_AI_DISPATCH_SYNC=true
WHATSAPP_AI_GREETING_BUTTONS=true
# Defaults below can be overridden in Admin → WhatsApp AI support → Status (whatsapp_ai_settings). GEMINI_API_KEY stays .env-only.
# Max polite clarification questions before auto human handoff (report_unclear_user_intent). Default 2.
# WHATSAPP_AI_UNCLEAR_MAX_CLARIFY_ROUNDS=2
# Address → zone auto-match (WhatsApp AI). Score must reach min; second-best within ratio = ambiguous.
# WHATSAPP_AI_ZONE_MATCH_MIN_SCORE_HIGH=10
# WHATSAPP_AI_ZONE_MATCH_AMBIGUITY_RATIO=0.88
# gemini-2.0-* is deprecated (often 404). flash-lite = fastest replies; flash = higher quality.
WHATSAPP_GEMINI_MODEL=gemini-2.5-flash-lite
# Optional tuning (defaults in Modules/WhatsAppModule/Config/config.php):
# WHATSAPP_GEMINI_HTTP_TIMEOUT=32
# WHATSAPP_GEMINI_MAX_OUTPUT_TOKENS=896
# WHATSAPP_GEMINI_TEMPERATURE=0.35
# WHATSAPP_AI_GEMINI_CONTEXT_TURNS=18
# WHATSAPP_AI_GEMINI_CONTEXT_CHAR_LIMIT=2200
# WHATSAPP_AI_GEMINI_MAX_TOOL_ROUNDS=6

# Admin AI playground (sandbox phone key; no WhatsApp Cloud send). Comma-separated extra keys optional.
# WHATSAPP_AI_PLAYGROUND_PHONE=AI_TEST_SANDBOX
# WHATSAPP_AI_PLAYGROUND_PHONES_EXTRA=
WHATSAPP_SUPPORT_HOURS_START=09:00
WHATSAPP_SUPPORT_HOURS_END=18:00
# Customer-facing support times are fixed to IST (Asia/Kolkata) in app; this env key is unused for AI/handoff.
# WHATSAPP_SUPPORT_TIMEZONE=Asia/Kolkata
# Admin chat message timestamps (whatsapp_messages created_at display + new rows)
WHATSAPP_MESSAGE_TIMEZONE=Asia/Kolkata
WHATSAPP_SUPPORT_PHONE_DISPLAY=
# Fallback {email}, {website}, {address} for WhatsApp AI when DB overrides + business settings are empty
# WHATSAPP_PLACEHOLDER_DEFAULT_EMAIL=
# WHATSAPP_PLACEHOLDER_DEFAULT_WEBSITE=
# WHATSAPP_PLACEHOLDER_DEFAULT_ADDRESS=
# WHATSAPP_PLACEHOLDER_DEFAULT_TAGLINE=
# Optional: URL shared when customers ask to join as providers (also configurable in config/whatsapp_ai_support.php)
# WHATSAPP_PROVIDER_ONBOARDING_URL=

# WhatsApp (PostgreSQL) - separate DB for chats/conversations/bookings
DB_WHATSAPP_HOST=127.0.0.1
DB_WHATSAPP_PORT=5432
DB_WHATSAPP_DATABASE=whatsapp
DB_WHATSAPP_USERNAME=postgres
DB_WHATSAPP_PASSWORD=
DB_WHATSAPP_SCHEMA=public
DB_WHATSAPP_SSLMODE=prefer

# Admin UI: cache customer/provider phone sets for WhatsApp ↔ system matching (seconds). 0 = rebuild every request.
WHATSAPP_SYSTEM_PHONE_MATCH_CACHE_TTL=300

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
# Laravel queue: "sync" = run jobs immediately in the HTTP request (no worker, good for local dev).
# "database" = store jobs in the `jobs` table; requires php artisan migrate and a running worker: php artisan queue:work
# For WhatsApp AI background processing, use QUEUE_CONNECTION=database with WHATSAPP_AI_DISPATCH_SYNC=false.
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

FORCE_HTTPS=false
SOFTWARE_ID=NDAyMjQ3NzI=
